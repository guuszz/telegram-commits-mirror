# Token do bot — pegar com @BotFather no Telegram
# 1. Fala /newbot pro @BotFather
# 2. Escolhe nome (ex: "Meus Commits")
# 3. Escolhe username (ex: meuscommits_bot)
# 4. Copia o token que ele te dá
TELEGRAM_BOT_TOKEN=

# Chat ID destino — pode ser:
# - DM com você mesmo: fala /start com o bot, depois acessa
#   https://api.telegram.org/bot<TOKEN>/getUpdates e pega o "id" do chat
# - Canal: adiciona o bot como admin no canal, posta qualquer msg, mesma API.
#   Canais usam ID negativo, tipo -1001234567890
TELEGRAM_CHAT_ID=

# Secret usado pra validar assinatura HMAC do GitHub
# Gere algo random tipo: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=
